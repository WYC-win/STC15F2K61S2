   4          void Uart1_Init(void)   //9600bps@12.000MHz
   5          {
   6   1              SCON = 0x50;            //8位数据,可变波特率
   7   1              AUXR |= 0x01;           //串口1选择定时器2为波特率发生器
   8   1              AUXR &= 0xFB;           //定时器时钟12T模式
   9   1              T2L = 0xE6;                     //设置定时初始值
