 135          /* ====================== 界面显示 ====================== */
 136          void environment_display(void)
 137          {
 138   1          digital_tubefixed(1, 12);              /* C */
 139   1          digital_tubefixed(2, tem % 100 / 10);
 140   1          digital_tubefixed(3, tem % 10);
 141   1          digital_tube(7, 0xC8);                 /* n */
 142   1          digital_tubefixed(8, light_level);
 143   1      }
 144          
 145          void move_display(void)
 146          {
 147   1          digital_tube(1, 0xC7);                 /* L */
 148   1          digital_tubefixed(2, move_state);
 149   1          digital_tubefixed(6, distance / 100);
 150   1          digital_tubefixed(7, distance % 100 / 10);
 151   1          digital_tubefixed(8, distance % 10);
 152   1      }
 153          
 154          void parameter_display(void)
 155          {
 156   1          digital_tube(1, 0x8C);                 /* P */
 157   1      
 158   1          if(para_page == PARA_PC)
 159   1          {
 160   2              digital_tubefixed(2, 12);          /* C */
 161   2              digital_tubefixed(7, tem_para / 10);
 162   2              digital_tubefixed(8, tem_para % 10);
 163   2          }
 164   1          else
 165   1          {
 166   2              digital_tube(2, 0xC7);             /* L */
 167   2              digital_tubefixed(7, dis_para / 10);
 168   2              digital_tubefixed(8, dis_para % 10);
 169   2          }
 170   1      }
 171          
 172          void stat_display(void)
 173          {
 174   1          digital_tube(1, 0xC8);                 /* n */
 175   1          digital_tubefixed(2, 12);              /* C */
 176   1          digital_tubefixed(5, relay_count / 1000 % 10);
 177   1          digital_tubefixed(6, relay_count / 100 % 10);
 178   1          digital_tubefixed(7, relay_count / 10 % 10);
C51 COMPILER V9.57.0.0   MAIN                                                              03/07/2026 13:56:47 PAGE 4   

 179   1          digital_tubefixed(8, relay_count % 10);
 180   1      }
