  10          /* ====================== 锁存选择 ====================== */
  11          #define LATCH_Y4C 0x80   /* LED */
  12          #define LATCH_Y5C 0xA0   /* 继电器/蜂鸣器/电机/步进/喇叭 */
  13          
  14          /* ====================== Y4C: LED 位定义 ====================== */
  15          /* 原理图 U6: D0~D7 -> Q0~Q7 -> L1~L8，低电平点亮 */
  16          #define LED1 0x01
  17          #define LED2 0x02
  18          #define LED3 0x04
  19          #define LED4 0x08
  20          #define LED5 0x10
  21          #define LED6 0x20
  22          #define LED7 0x40
  23          #define LED8 0x80
  24          
  25          /* ====================== Y5C: 执行器位定义 ====================== */
  26          /* 原理图 U9 -> ULN2003A:
  27             D0->N_SPK, D1->STEPA, D2->STEPB, D3->STEPC,
  28             D4->STEPD, D5->N_RELAY, D6->N_MOTOR, D7->N_BUZZ */
  29          #define SPK_BIT    0x01
  30          #define STEPA_BIT  0x02
  31          #define STEPB_BIT  0x04
  32          #define STEPC_BIT  0x08
  33          #define STEPD_BIT  0x10
  34          #define RELAY_BIT  0x20
  35          #define MOTOR_BIT  0x40
  36          #define BUZZ_BIT   0x80
  37          
  38          /* ====================== 按键值定义 ====================== */
  39          /* 继承你当前矩阵键盘映射 */
  40          #define KEY_S4 4
  41          #define KEY_S5 5
  42          #define KEY_S8 8
  43          #define KEY_S9 9
  44          
  45          /* ====================== 页面定义 ====================== */
  46          #define PAGE_ENV   0
  47          #define PAGE_MOVE  1
  48          #define PAGE_PARA  2
  49          #define PAGE_STAT  3
  50          
  51          #define PARA_PC    0
  52          #define PARA_PL    1
  53          
  54          #define MOVE_STOP  1
C51 COMPILER V9.57.0.0   MAIN                                                              03/07/2026 13:56:47 PAGE 2   

  55          #define MOVE_WALK  2
  56          #define MOVE_RUN   3
