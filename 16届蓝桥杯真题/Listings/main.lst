  92          /* ====================== 锁存输出函数 ====================== */
  93          void latch_write(unsigned char dat, unsigned char sel)
  94          {
  95   1          P0 = dat;
  96   1          P2 = (P2 & 0x1F) | sel;
  97   1          P2 &= 0x1F;       //取消选通
  98   1      }
  99          
 100          /* LED 低电平点亮 */
 101          void led_write(unsigned char led_on)
 102          {
 103   1          latch_write(~led_on, LATCH_Y4C);
 104   1      }
 105          
 106          /* Y5C 高电平有效 */
 107          void y5_write(unsigned char y5_on)
 108          {
 109   1          latch_write(y5_on, LATCH_Y5C);
 110   1      }
