 365   2              {
 366   3                  para_page++;
 367   3                  if(para_page >= 2) para_page = 0;
 368   3              }
 369   2      
 370   2              if(key == KEY_S8)
 371   2              {
 372   3                  if(para_page == PARA_PC)
 373   3                  {
 374   4                      if(tem_para < 80) tem_para++;
 375   4                  }
 376   3                  else
 377   3                  {
 378   4                      if(dis_para <= 75) dis_para += 5;
 379   4                  }
 380   3              }
 381   2      
 382   2              if(key == KEY_S9)
 383   2              {
 384   3                  if(para_page == PARA_PC)
 385   3                  {
 386   4                      if(tem_para > 20) tem_para--;
 387   4                  }
 388   3                  else
 389   3                  {
 390   4                      if(dis_para >= 25) dis_para -= 5;
 391   4                  }
 392   3              }
 393   2          }
 394   1      }
