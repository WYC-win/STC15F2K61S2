  91          /* ====================== 锁存输出函数 ====================== */
  92          void latch_write(unsigned char dat, unsigned char sel)
  93          {
  94   1          P0 = dat;
  95   1          P2 = (P2 & 0x1F) | sel;
  96   1          P2 &= 0x1F;
  97   1      }
  98          
  99          /* LED 低电平点亮 */
 100          void led_write(unsigned char led_on)
 101          {
 102   1          latch_write(~led_on, LATCH_Y4C);
 103   1      }
 104          
 105          /* Y5C 高电平有效 */
 106          void y5_write(unsigned char y5_on)
 107          {
 108   1          latch_write(y5_on, LATCH_Y5C);
 109   1      }
