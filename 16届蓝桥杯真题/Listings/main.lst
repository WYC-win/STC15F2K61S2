 206          
 207          /* ====================== 状态判断 ====================== */
 208          void judge_state(void)
 209          {
 210   1          if((distance > 0) && (distance < dis_para)) near_flag = 1;
 211   1          else near_flag = 0;
 212   1      
 213   1          if(tem > tem_para) hot_flag = 1;
 214   1          else hot_flag = 0;
 215   1      }
 216          
 217          void update_move_state(void)
 218          {
 219   1          unsigned int delta;
 220   1      
 221   1          if(distance >= last_distance) delta = distance - last_distance;
 222   1          else delta = last_distance - distance;
 223   1      
 224   1          if(move_lock_ms != 0) return;//return 直接退出
 225   1      
 226   1          if(delta < 5) move_state = MOVE_STOP;
 227   1          else if(delta < 10) move_state = MOVE_WALK;
 228   1          else move_state = MOVE_RUN;
 229   1      
 230   1          move_lock_ms = 3000;    /* 锁定3秒 */
 231   1      }
 232          
 233          /* ====================== 输出控制 ====================== */
 234          void output_update(void)
 235          {
 236   1          unsigned char led_on = 0x00;
