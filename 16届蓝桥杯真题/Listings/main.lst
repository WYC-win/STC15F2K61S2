  29             D4->STEPD, D5->N_RELAY, D6->N_MOTOR, D7->N_BUZZ */
  30          #define SPK_BIT    0x01
  31          #define STEPA_BIT  0x02
  32          #define STEPB_BIT  0x04
  33          #define STEPC_BIT  0x08
  34          #define STEPD_BIT  0x10
  35          #define RELAY_BIT  0x20
