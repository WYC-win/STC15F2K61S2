 113          void Timer0_Init(void)      /* 1ms @ 12.000MHz, 12T */
 114          {
 115   1          AUXR &= 0x7F;
 116   1          TMOD &= 0xF0;
C51 COMPILER V9.57.0.0   MAIN                                                              03/08/2026 16:04:36 PAGE 3   

 117   1          TMOD |= 0x01;
 118   1          TL0 = 0x18;
 119   1          TH0 = 0xFC;
 120   1          TF0 = 0;
 121   1          ET0 = 1;
 122   1          EA  = 1;
 123   1          TR0 = 1;
 124   1      }
 125          
 126          void Timer0_Isr(void) interrupt 1
 127          {
 128   1          TL0 = 0x18;
 129   1          TH0 = 0xFC;
 130   1          ms++;
 131   1      
 132   1          if(move_lock_ms > 0) move_lock_ms--;
 133   1          if(blink_ms > 0) blink_ms--;
 134   1      }
