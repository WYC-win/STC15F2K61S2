 111          /* ====================== 定时器0 1ms ====================== */
 112          void Timer0_Init(void)      /* 1ms @ 12.000MHz, 12T */
 113          {
 114   1          AUXR &= 0x7F;
 115   1          TMOD &= 0xF0;
 116   1          TMOD |= 0x01;
C51 COMPILER V9.57.0.0   MAIN                                                              03/07/2026 13:56:47 PAGE 3   

 117   1          TL0 = 0x18;
 118   1          TH0 = 0xFC;
 119   1          TF0 = 0;
 120   1          ET0 = 1;
 121   1          EA  = 1;
 122   1          TR0 = 1;
 123   1      }
 124          
 125          void Timer0_Isr(void) interrupt 1
 126          {
 127   1          TL0 = 0x18;
 128   1          TH0 = 0xFC;
 129   1          ms++;
 130   1      
 131   1          if(move_lock_ms > 0) move_lock_ms--;
 132   1          if(blink_ms > 0) blink_ms--;
 133   1      }
