 336          /* ====================== 按键处理 ====================== */
 337          void key_proc(void)
 338          {
 339   1          unsigned char key;
 340   1      
 341   1          key = keynumber_nb();
 342   1          if(key == 0) return;
 343   1      
 344   1          /* S4 切界面 */
 345   1          if(key == KEY_S4)
 346   1          {
 347   2              page++;
 348   2              if(page >= 4) page = 0;
 349   2      
 350   2              if(page == PAGE_PARA)
 351   2              {
 352   3                  para_page = PARA_PC;
 353   3                  output_lock = 1;
 354   3              }
 355   2              else
 356   2              {
 357   3                  output_lock = 0;
 358   3              }
 359   2          }
 360   1      
 361   1          /* 参数界面按键 */
 362   1          if(page == PAGE_PARA)
 363   1          {
 364   2              if(key == KEY_S5)
