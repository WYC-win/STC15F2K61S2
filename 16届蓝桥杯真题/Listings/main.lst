  94          /* ====================== 锁存输出函数 ====================== */
  95          void latch_write(unsigned char dat, unsigned char sel)
  96          {
  97   1          P0 = dat;
  98   1          P2 = (P2 & 0x1F) | sel;
  99   1          P2 &= 0x1F;       //取消选通
 100   1      }
