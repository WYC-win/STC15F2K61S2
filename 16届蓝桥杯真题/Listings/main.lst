 182          /* ====================== 数据采集 ====================== */
 183          void read_temp_data(void)
 184          {
 185   1          DS18B20_convertT();
 186   1          tem = (unsigned int)(DS18B20_readT() + 0.5);
 187   1      }
 188          
 189          void read_light_data(void)
 190          {
 191   1          /* AIN1 */
 192   1          light_adc = AD_read(0x41);
 193   1      
 194   1          if(light_adc >= 153) light_level = 1;
 195   1          else if(light_adc >= 102) light_level = 2;
 196   1          else if(light_adc >= 25) light_level = 3;
 197   1          else light_level = 4;
 198   1      }
 199          
 200          void read_distance_data(void)
 201          {
 202   1          last_distance = distance;
 203   1          distance = superwave_getdistance();
 204   1      }
 205          
 206          /* ====================== 状态判断 ====================== */
 207          void judge_state(void)
 208          {
 209   1          if((distance > 0) && (distance < dis_para)) near_flag = 1;
 210   1          else near_flag = 0;
 211   1      
 212   1          if(tem > tem_para) hot_flag = 1;
 213   1          else hot_flag = 0;
 214   1      }
 215          
 216          void update_move_state(void)
 217          {
 218   1          unsigned int delta;
 219   1      
 220   1          if(distance >= last_distance) delta = distance - last_distance;
 221   1          else delta = last_distance - distance;
 222   1      
 223   1          if(move_lock_ms != 0) return;
 224   1      
 225   1          if(delta < 5) move_state = MOVE_STOP;
 226   1          else if(delta < 10) move_state = MOVE_WALK;
 227   1          else move_state = MOVE_RUN;
 228   1      
 229   1          move_lock_ms = 3000;    /* 锁定3秒 */
 230   1      }
 231          
 232          /* ====================== 输出控制 ====================== */
 233          void output_update(void)
 234          {
 235   1          unsigned char led_on = 0x00;
 236   1          unsigned char y5_on  = 0x00;
 237   1          bit relay_now;
 238   1      
 239   1          if(output_lock)
 240   1          {
C51 COMPILER V9.57.0.0   MAIN                                                              03/07/2026 13:56:47 PAGE 5   

 241   2              led_write(led_keep);
 242   2              y5_write(y5_keep);
 243   2              return;
 244   2          }
 245   1      
 246   1          /* 接近时，L1~L4 显示光强等级 */
 247   1          if(near_flag)
 248   1          {
 249   2              if(light_level == 1) led_on |= LED1;
 250   2              else if(light_level == 2) led_on |= (LED1 | LED2);
 251   2              else if(light_level == 3) led_on |= (LED1 | LED2 | LED3);
 252   2              else led_on |= (LED1 | LED2 | LED3 | LED4);
 253   2          }
 254   1      
 255   1          /* L8 显示运动状态 */
 256   1          if(move_state == MOVE_WALK)
 257   1          {
 258   2              led_on |= LED8;
 259   2          }
 260   1          else if(move_state == MOVE_RUN)
 261   1          {
 262   2              if(blink_ms == 0)
 263   2              {
 264   3                  blink_ms = 100;       /* 100ms 翻转一次 */
 265   3                  blink_flag = !blink_flag;
 266   3              }
 267   2              if(blink_flag) led_on |= LED8;
 268   2          }
 269   1      
 270   1          /* 接近 + 高温 -> 吸合继电器 */
 271   1          if(near_flag && hot_flag)
 272   1          {
 273   2              y5_on |= RELAY_BIT;
 274   2          }
 275   1      
 276   1          /* 继电器吸合次数统计：上升沿计数 */
 277   1          relay_now = (y5_on & RELAY_BIT) ? 1 : 0;
 278   1          if(relay_now && !relay_last)
 279   1          {
 280   2              relay_count++;
 281   2          }
 282   1          relay_last = relay_now;
 283   1      
 284   1          led_write(led_on);
 285   1          y5_write(y5_on);
 286   1      
 287   1          led_keep = led_on;
 288   1          y5_keep  = y5_on;
 289   1      }
