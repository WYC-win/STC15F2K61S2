  35          void T1_Proc(void) interrupt 3
  36          {
  37   1        if (++uiTms == 1000)                // 1s时间到
  38   1        {
  39   2          uiTms = 0;
  40   2          uiSec++;
  41   2        }
  42   1        uiSeg_Dly++;
