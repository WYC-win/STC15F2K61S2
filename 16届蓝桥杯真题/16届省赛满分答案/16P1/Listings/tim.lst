  60          sbit CR     = CCON^6;                 // PCA运行控制位
  61          sbit CF     = CCON^7;                 // PCA溢出标志位
  62          
  63          sfr  P1     = 0x90;
  64          sbit TX     = P1^0;
  65          sbit RX     = P1^1;
  66          
  67          unsigned char Dist_Meas(void)
  68          {
  69   1        unsigned char ucNum = 10;
  70   1      
  71   1        // TX引脚发送40KHz方波信号驱动超声波发送探头
  72   1        TX = 0;
  73   1        CL = 0xf4;                          // 设置PCA低8位定时值
  74   1        CH = 0xff;                          // 设置PCA高8位定时值
  75   1        CR = 1;                             // 启动PCA
  76   1        while (ucNum--)
  77   1        {
  78   2          while (!CF);                      // 等待PCA定时时间到
  79   2          TX ^= 1;                          // 翻转TX
  80   2          CL = 0xf4;                        // 重置PCA低8位定时值
  81   2          CH = 0xff;                        // 重置PCA高8位定时值
  82   2          CF = 0;
  83   2        }
  84   1        CR = 0;                             // 关闭PCA
  85   1        // 接收计时
  86   1        CL = 0;                             // 设置PCA低8位定时值
  87   1        CH = 0;                             // 设置PCA高8位定时值
  88   1        CR = 1;
  89   1        while(RX && !CF);                   // 等待下降沿
  90   1        CR = 0;
  91   1        return ((CH<<8)+CL)*0.017;          // 计算距离：340*100/1000000/2
  92   1      }


