  48   1        if (ucSeg_Dly >= 2)                 // 2ms移位1次
  49   1        {
  50   2          ucSeg_Dly = 0;
  51   2      
  52   2          Seg_Disp(pucSeg_Code[ucSeg_Pos], ucSeg_Pos);
  53   2          ucSeg_Pos = ++ucSeg_Pos & 7;      // 数码管循环显示
