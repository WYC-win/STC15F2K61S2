  17   1        TMOD &= 0x0F;                       // 设置定时器模式
  18   1        TL1 = 0x18;                         // 设置定时初值（24）
  19   1        TH1 = 0xFC;                         // 设置定时初值（252）
  20   1        TF1 = 0;                            // 清除TF1标志
