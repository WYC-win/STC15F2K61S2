 180          //==================== Timer0初始化(LED模式, 1ms时基) ====================
 181          void Timer0_LED_Init(void)      //1毫秒@12.000MHz
 182          {
 183   1          AUXR &= 0x7F;               //定时器时钟12T模式
 184   1          TMOD &= 0xF0;               //设置定时器模式
 185   1          TMOD |= 0x01;               //定时器0模式1(16位)
 186   1          TL0 = 0x18;                 //设置定时初始值 65536-1000=64536
 187   1          TH0 = 0xFC;
 188   1          TF0 = 0;                    //清除TF0标志
 189   1          TR0 = 1;                    //定时器0开始计时
 190   1          ET0 = 1;                    //使能定时器0中断
 191   1      }
 192          
 193          //==================== Timer0初始化(DA模式, us级间隔) ====================
 194          void Timer0_DA_Init(unsigned int us)
 195          {
 196   1          unsigned int ticks;
 197   1          ticks = 65536 - us;
 198   1      
 199   1          AUXR &= 0x7F;               //定时器时钟12T模式
 200   1          TMOD &= 0xF0;
 201   1          TMOD |= 0x01;               //定时器0模式1
 202   1          TL0 = ticks & 0xFF;
 203   1          TH0 = ticks >> 8;
 204   1          TF0 = 0;
 205   1          TR0 = 1;
 206   1          ET0 = 1;
 207   1      }
