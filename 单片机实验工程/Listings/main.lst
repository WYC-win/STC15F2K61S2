 496          //==================== Timer0中断服务 ====================
 497          void Timer0_Isr(void) interrupt 1
 498          {
 499   1          unsigned int reload;
 500   1          unsigned char val;
 501   1      
 502   1          if(page_count == state_led)
 503   1          {
 504   2              // LED模式：1ms时基
 505   2              TL0 = 0x18;
 506   2              TH0 = 0xFC;
 507   2      
 508   2              led_tick++;
 509   2              refresh_count++;            // 1ms计数，用于LCD刷新
 510   2              if(led_tick >= led_interval)
 511   2              {
 512   3                  led_tick = 0;
 513   3                  // 跑马灯移位
 514   3                  if(led_pattern == 0x7F)
 515   3                      led_pattern = 0xFE;
 516   3                  else
 517   3                      led_pattern = (led_pattern << 1) | 0x01;
 518   3                  P0 = led_pattern;
 519   3                  latch(4);
 520   3              }
 521   2          }
 522   1          else if(page_count >= state_da_saw && page_count <= state_da_sin)
 523   1          {
 524   2              // DA模式：波形输出
 525   2              reload = 65536 - (1000000UL / (64 * da_freq));
 526   2              TL0 = reload & 0xFF;
 527   2              TH0 = reload >> 8;
 528   2      
 529   2              da_index++;
 530   2              if(da_index >= 64)
 531   2                  da_index = 0;
 532   2      
 533   2              if(page_count == state_da_saw)
 534   2                  val = da_index * 4;                     // 锯齿波
 535   2              else if(page_count == state_da_tri)
 536   2              {
 537   3                  if(da_index < 32)
 538   3                      val = da_index * 8;                 // 三角波上升
 539   3                  else
 540   3                      val = (63 - da_index) * 8;          // 三角波下降
 541   3              }
 542   2              else
 543   2                  val = sin_tab[da_index];                // 正弦波查表
 544   2      
 545   2              da_val = val;       // 传给主循环输出
 546   2              da_flag = 1;
 547   2          }
