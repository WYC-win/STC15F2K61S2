 137          void Uart1_Init(void)   //9600bps@12.000MHz
 138          {
 139   1              SCON = 0x50;            //8位数据,可变波特率
 140   1              AUXR &= 0xBF;           //定时器时钟12T模式
 141   1              AUXR &= 0xFE;           //串口1选择定时器1为波特率发生器
 142   1              TMOD &= 0x0F;           //设置定时器模式
 143   1              TL1 = 0xE6;                     //设置定时初始值
 144   1              TH1 = 0xFF;                     //设置定时初始值
 145   1              ET1 = 0;                        //禁止定时器中断
 146   1              TR1 = 1;                        //定时器1开始计时
 147   1              ES = 1;                         //使能串口1中断
 148   1      }
 149          
 150          //==================== 串口发送 ====================
 151          void uart_send_byte(unsigned char dat)
 152          {
 153   1          SBUF = dat;
 154   1          while(TI == 0);
 155   1          TI = 0;
 156   1      }
 157          
 158          void uart_send_string(char *str)
 159          {
 160   1          while(*str != '\0')
 161   1              uart_send_byte(*str++);
 162   1      }
 163          
 164          void uart_send_num(unsigned int num)
 165          {
 166   1          uart_send_byte(num/1000%10 + '0');
 167   1          uart_send_byte(num/100%10 + '0');
 168   1          uart_send_byte(num/10%10 + '0');
 169   1          uart_send_byte(num%10 + '0');
 170   1      }
