 501          //==================== Timer0中断服务 ====================
 502          void Timer0_Isr(void) interrupt 1
 503          {
 504   1          unsigned int reload;
 505   1          unsigned char val;
 506   1      
 507   1          if(page_count == state_led)
 508   1          {
 509   2              // LED模式：1ms时基
 510   2              TL0 = 0x18;
 511   2              TH0 = 0xFC;
 512   2      
 513   2              led_tick++;
 514   2              refresh_count++;            // 1ms计数，用于LCD刷新
 515   2              if(led_tick >= led_interval)
 516   2              {
 517   3                  led_tick = 0;
 518   3                  // 跑马灯移位
 519   3                  if(led_pattern == 0x7F)
 520   3                      led_pattern = 0xFE;
 521   3                  else
 522   3                      led_pattern = (led_pattern << 1) | 0x01;
 523   3                  P0 = led_pattern;
 524   3                  latch(4);
 525   3              }
 526   2          }
 527   1          else if(page_count >= state_da_saw && page_count <= state_da_sin)
 528   1          {
 529   2              // DA模式：波形输出
 530   2              reload = 65536 - (1000000UL / (64 * da_freq));
 531   2              TL0 = reload & 0xFF;
 532   2              TH0 = reload >> 8;
 533   2      
 534   2              da_index++;
 535   2              if(da_index >= 64)
 536   2                  da_index = 0;
 537   2      
 538   2              if(page_count == state_da_saw)
 539   2                  val = da_index * 4;                     // 锯齿波
 540   2              else if(page_count == state_da_tri)
 541   2              {
 542   3                  if(da_index < 32)
 543   3                      val = da_index * 8;                 // 三角波上升
 544   3                  else
 545   3                      val = (63 - da_index) * 8;          // 三角波下降
 546   3              }
 547   2              else
 548   2                  val = sin_tab[da_index];                // 正弦波查表
