 173          void Timer0_LED_Init(void)      //1毫秒@12.000MHz
 174          {
 175   1          AUXR &= 0x7F;               //定时器时钟12T模式
 176   1          TMOD &= 0xF0;               //设置定时器模式
 177   1          TMOD |= 0x01;               //定时器0模式1(16位)
 178   1          TL0 = 0x18;                 //设置定时初始值 65536-1000=64536
C51 COMPILER V9.57.0.0   MAIN                                                              06/07/2026 17:49:47 PAGE 4   

 179   1          TH0 = 0xFC;
 180   1          TF0 = 0;                    //清除TF0标志
 181   1          TR0 = 1;                    //定时器0开始计时
 182   1          ET0 = 1;                    //使能定时器0中断
 183   1      }
 184          
 185          //==================== Timer0初始化(DA模式, us级间隔) ====================
 186          void Timer0_DA_Init(unsigned int us)
 187          {
 188   1          unsigned int ticks;
 189   1          ticks = 65536 - us;
 190   1      
 191   1          AUXR &= 0x7F;               //定时器时钟12T模式
 192   1          TMOD &= 0xF0;
 193   1          TMOD |= 0x01;               //定时器0模式1
 194   1          TL0 = ticks & 0xFF;
 195   1          TH0 = ticks >> 8;
 196   1          TF0 = 0;
 197   1          TR0 = 1;
 198   1          ET0 = 1;
 199   1      }
