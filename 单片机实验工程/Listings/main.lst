 145          void Uart1_Init(void)   //9600bps@12.000MHz
 146          {
 147   1              SCON = 0x50;            //8位数据,可变波特率
 148   1              AUXR &= 0xBF;           //定时器时钟12T模式
 149   1              AUXR &= 0xFE;           //串口1选择定时器1为波特率发生器
 150   1              TMOD &= 0x0F;           //设置定时器模式
 151   1              TL1 = 0xE6;                     //设置定时初始值
 152   1              TH1 = 0xFF;                     //设置定时初始值
 153   1              ET1 = 0;                        //禁止定时器中断
 154   1              TR1 = 1;                        //定时器1开始计时
 155   1              ES = 1;                         //使能串口1中断
 156   1      }
 157          
 158          //==================== 串口发送 ====================
 159          void uart_send_byte(unsigned char dat)
 160          {
 161   1          SBUF = dat;
 162   1          while(TI == 0);
 163   1          TI = 0;
 164   1      }
 165          
 166          void uart_send_string(char *str)
 167          {
 168   1          while(*str != '\0')
 169   1              uart_send_byte(*str++);
 170   1      }
 171          
 172          void uart_send_num(unsigned int num)
 173          {
 174   1          uart_send_byte(num/1000%10 + '0');
 175   1          uart_send_byte(num/100%10 + '0');
 176   1          uart_send_byte(num/10%10 + '0');
 177   1          uart_send_byte(num%10 + '0');
 178   1      }
